# =================================================================
# Supabase
# =================================================================
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Settings → API → service_role key (NÃO é a anon key)
# Usada apenas no servidor; bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Nome do bucket de Storage para fotos (criar manualmente no Dashboard)
SUPABASE_STORAGE_BUCKET=lacos

# =================================================================
# Admin (acesso ao /admin/login)
# =================================================================
# Sem essas variáveis, o app usa "admin" como senha (apenas para dev).
ADMIN_PASSWORD=troque-por-uma-senha-forte

# String aleatória usada para assinar o cookie de sessão (HMAC-SHA256).
# Gere com:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=cole-aqui-uma-string-longa-aleatoria
